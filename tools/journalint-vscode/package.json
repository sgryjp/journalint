{
  "name": "journalint",
  "displayName": "journalint",
  "publisher": "sgryjp",
  "author": {
    "name": "Suguru Yamamoto",
    "email": "sgryjp@gmail.com",
    "url": "https://github.com/sgryjp"
  },
  "description": "Linter for my personal journal files.",
  "license": "(MIT OR Apache-2.0)",
  "version": "24.6.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/sgryjp/journalint.git"
  },
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "run-script-os",
    "compile:darwin:linux": "cd ../.. && sh scripts/compile-crates.sh && sh scripts/compile-node.sh",
    "compile:win32": "cd ../.. && powershell scripts/compile-crates.ps1 && powershell scripts/compile-node.ps1",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier -w .",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.98.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.3.0",
    "prettier": "^3.5.3",
    "run-script-os": "^1.1.6",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^8.0.3"
  }
}
